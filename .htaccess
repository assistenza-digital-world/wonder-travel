# ============================================================================
# Wonder Travel — Apache (.htaccess) per Cloudways Hybrid Stack
# SPA fallback (React Router) + cache asset + sicurezza.
# ============================================================================

# --- Fallback SPA: ogni percorso non-file viene servito da index.html ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forza HTTPS (Cloudways gestisce il certificato Let's Encrypt)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Canonicalizza www -> apex (un solo host, coerente con i canonical)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Sito mono-lingua (portoghese) alla root. I vecchi percorsi /it e /br
  # (e relative sottopagine) reindirizzano in modo permanente all'equivalente
  # alla radice: /br -> /, /br/privacy -> /privacy, /it/cookie -> /cookie, ecc.
  RewriteRule ^(?:it|br)/(.*)$ /$1 [R=301,L]
  RewriteRule ^(?:it|br)/?$ / [R=301,L]

  # Trailing slash sulle directory con redirect HTTPS diretto (evita il
  # passaggio per http:// del redirect automatico di mod_dir dietro proxy)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ https://wondertravel-tour.com/$1/ [L,R=301]

  # File o cartelle reali (asset, immagini, lead.php) -> serviti direttamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Tutto il resto (/it, /br, /it/grazie, ...) -> index.html
  RewriteRule ^ index.html [L]
</IfModule>

# --- Protezione file sensibili (log dei lead, env, dotfiles) ---
<FilesMatch "(\.log|\.env.*|\.git.*|composer\.(json|lock))$">
  Require all denied
</FilesMatch>

# --- Include PHP non destinati ad accesso diretto (difesa in profondità) ---
<FilesMatch "^(secrets|secrets\.example|db|smtp-mailer|ratelimit)\.php$">
  Require all denied
</FilesMatch>

# --- Compressione ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# --- Cache: asset con hash = immutabili a lungo; index.html mai in cache ---
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|avif|jpe?g|png|gif|woff2?|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Sicurezza di base
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # HSTS (HTTPS è già forzato sopra). 180g: alza a 1 anno + includeSubDomains
  # quando hai verificato che TUTTI i sottodomini sono in HTTPS.
  Header always set Strict-Transport-Security "max-age=15552000"

  # CSP in sola segnalazione (NON blocca nulla): riflette l'uso reale del sito
  # (asset same-origin, stili/script inline di framer-motion e del fix di scroll).
  # Promuovila a "Content-Security-Policy" quando i report sono puliti.
  Header set Content-Security-Policy-Report-Only "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
</IfModule>

# --- Fallback MIME per webp/avif (in caso il server non li riconosca) ---
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
</IfModule>

ErrorDocument 404 /index.html
